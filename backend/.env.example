# Copy this file to .env and fill in the values
# cp .env.example .env

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (Neon) — leave blank to use SQLite in local dev
# DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/dbname?sslmode=require

# Cloudinary — leave blank to use local media/ folder in local dev
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# CORS — Cloudflare Pages domain
# CORS_ALLOWED_ORIGINS=https://your-app.pages.dev,http://localhost:5500,http://localhost:3000
